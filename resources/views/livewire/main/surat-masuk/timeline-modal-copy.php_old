                    array('id' => 2, 'parent_id' => 0, 'name' => 'Node 2'),
                    array('id' => 3, 'parent_id' => 1, 'name' => 'Node 1.1'),
                    array('id' => 4, 'parent_id' => 1, 'name' => 'Node 1.2'),
                    array('id' => 5, 'parent_id' => 3, 'name' => 'Node 1.1.1'),
                    array('id' => 6, 'parent_id' => 2, 'name' => 'Node 2.1'),
                    array('id' => 7, 'parent_id' => 2, 'name' => 'Node 2.2'),
                );

                // Fungsi untuk membuat tree view
                function buildTreeView($items, $parentId = 0) {
                    $html = '';

                    foreach ($items as $item) {
                        if ($item['parent_id'] == $parentId) {
                            $html .= '<li>' . $item['name'];
            
                            // Recursive call for child nodes
                            $html .= '<ul>' . buildTreeView($items, $item['id']) . '</ul>';
            
                            $html .= '</li>';
                        }
                    }

                    return $html;
                }

                // Output HTML untuk tree view
                echo '<ul>' . buildTreeView($data) . '</ul>';

