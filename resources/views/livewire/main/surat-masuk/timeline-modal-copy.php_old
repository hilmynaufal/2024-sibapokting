                <style>
                  /* Gaya untuk tree view */
                  ul.tree {
                      list-style-type: none;
                      padding-left: 20px;
                  }

                  ul.tree li {
                      position: relative;
                      margin-left: -20px;
                      padding-left: 20px;
                      border-left: 1px solid #ccc;
                      margin-bottom: 5px;
                  }

                  /* Gaya untuk ikon collapse/expand */
                  ul.tree li:before {
                      content: '';
                      position: absolute;
                      top: 0;
                      left: -10px;
                      width: 0;
                      height: 100%;
                      border-left: 1px solid #ccc;
                      border-bottom: 1px solid #ccc;
                  }

                  /* Gaya untuk teks node */
                  ul.tree li > span {
                      cursor: pointer;
                      display: inline-block;
                      padding: 3px 8px;
                      background-color: #f4f4f4;
                      border: 1px solid #ccc;
                      border-radius: 3px;
                  }

                  /* Gaya untuk node terbuka */
                  ul.tree li.expanded > span:before {
                      content: '-';
                      margin-right: 5px;
                  }

                  /* Gaya untuk node tertutup */
                  ul.tree li.collapsed > span:before {
                      content: '+';
                      margin-right: 5px;
                  }
              </style>
